@model CartNestGaming.Models.Product

@{
    ViewData["Title"] = "Delete Product";
}

<style>
    body {
        background: radial-gradient(circle at top, #020617, #020617 40%, #0f172a);
        color: white;
        font-family: 'Segoe UI';
    }

    /* CONTAINER */
    .delete-container {
        max-width: 600px;
        margin: 60px auto;
        background: #1e293b;
        padding: 30px;
        border-radius: 15px;
        box-shadow: 0 0 20px rgba(248, 113, 113, 0.4);
        border: 1px solid #ef4444;
    }

    /* TITLE */
    h2 {
        text-align: center;
        color: #ef4444;
        text-shadow: 0 0 10px #ef4444;
    }

    h4 {
        text-align: center;
        color: #facc15;
    }

    /* DETAILS */
    .details dt {
        font-weight: bold;
        color: #94a3b8;
    }

    .details dd {
        margin-bottom: 10px;
    }

    /* BUTTONS */
    .btn {
        padding: 10px 15px;
        border-radius: 8px;
        border: none;
        cursor: pointer;
        text-decoration: none;
    }

    .btn-danger {
        background: #ef4444;
        color: white;
    }

        .btn-danger:hover {
            box-shadow: 0 0 15px #ef4444;
        }

    .btn-secondary {
        background: #64748b;
        color: white;
        margin-left: 10px;
    }

        .btn-secondary:hover {
            box-shadow: 0 0 10px #64748b;
        }

    /* BUTTON AREA */
    .btn-area {
        text-align: center;
        margin-top: 20px;
    }
</style>

<div class="delete-container">

    <h2>⚠️ Delete Product</h2>
    <h4>Are you sure you want to delete this game?</h4>

    <hr />

    <dl class="details">

        <dt>Name</dt>
        <dd>@Model.Name</dd>

        <dt>Description</dt>
        <dd>@Model.Description</dd>

        <dt>Price</dt>
        <dd>₹ @Model.Price</dd>

        <dt>Stock</dt>
        <dd>@Model.Stock</dd>

        <dt>Category</dt>
        <dd>@Model.Category?.Name</dd>

    </dl>

    <form asp-action="Delete" method="post">

        <!-- IMPORTANT -->
        <input type="hidden" asp-for="Id" />

        <div class="btn-area">
            <button type="submit" class="btn btn-danger">
                🗑 Confirm Delete
            </button>

            <a asp-action="Index" class="btn btn-secondary">
                Cancel
            </a>
        </div>

    </form>

</div>