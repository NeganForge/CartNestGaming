@model CartNestGaming.Models.Product

@{
    ViewData["Title"] = "Edit Product";
}

<style>
    body {
        background: radial-gradient(circle at top, #020617, #020617 40%, #0f172a);
        color: white;
        font-family: 'Segoe UI';
    }

    /* CONTAINER */
    .form-container {
        max-width: 500px;
        margin: 50px auto;
        background: #1e293b;
        padding: 30px;
        border-radius: 15px;
        box-shadow: 0 0 20px rgba(56, 189, 248, 0.3);
    }

    /* TITLE */
    h2 {
        text-align: center;
        color: #38bdf8;
        text-shadow: 0 0 10px #38bdf8;
    }

    /* INPUTS */
    .form-group {
        margin-bottom: 15px;
    }

    label {
        font-weight: bold;
    }

    input, select {
        width: 100%;
        padding: 10px;
        border-radius: 8px;
        border: none;
        margin-top: 5px;
        background: #020617;
        color: white;
        outline: none;
    }

        input:focus, select:focus {
            box-shadow: 0 0 10px #38bdf8;
        }

    /* BUTTONS */
    .btn {
        padding: 10px 15px;
        border-radius: 8px;
        border: none;
        cursor: pointer;
        text-decoration: none;
        margin-top: 10px;
    }

    .btn-success {
        background: #22c55e;
        color: white;
    }

        .btn-success:hover {
            box-shadow: 0 0 10px #22c55e;
        }

    .btn-secondary {
        background: #64748b;
        color: white;
        margin-left: 10px;
    }

        .btn-secondary:hover {
            box-shadow: 0 0 10px #64748b;
        }

    /* BUTTON AREA */
    .btn-area {
        text-align: center;
    }
</style>

<div class="form-container">

    <h2>✏️ Edit Product</h2>

    <form asp-action="Edit" method="post">

        <input type="hidden" asp-for="Id" />

        <!-- Name -->
        <div class="form-group">
            <label>Name</label>
            <input asp-for="Name" />
        </div>

        <!-- Description -->
        <div class="form-group">
            <label>Description</label>
            <input asp-for="Description" />
        </div>

        <!-- Price -->
        <div class="form-group">
            <label>Price</label>
            <input asp-for="Price" type="number" step="0.01" />
        </div>

        <!-- Stock -->
        <div class="form-group">
            <label>Stock</label>
            <input asp-for="Stock" type="number" />
        </div>

        <!-- Category -->
        <div class="form-group">
            <label>Category</label>
            <select asp-for="CategoryId">
                <option value="">-- Select Category --</option>

                @foreach (var cat in ViewBag.Categories)
                {
                    <option value="@cat.Id">@cat.Name</option>
                }
            </select>
        </div>

        <!-- Buttons -->
        <div class="btn-area">
            <button type="submit" class="btn btn-success">💾 Update</button>
            <a asp-action="Index" class="btn btn-secondary">⬅ Back</a>
        </div>

    </form>

</div>