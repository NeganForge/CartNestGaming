@model IEnumerable<CartNestGaming.Models.Product>

@{
    ViewData["Title"] = "Product List";
}

<style>
    body {
        background: #0f172a;
        color: white;
        font-family: 'Segoe UI';
    }

    /* TITLE */
    .title {
        color: #00f7ff;
        text-shadow: 0 0 12px #00f7ff;
    }

    /* BUTTONS */
    .btn-neon {
        background: linear-gradient(45deg, #00f7ff, #007bff);
        border: none;
        color: white;
        padding: 8px 15px;
        border-radius: 8px;
        text-decoration: none;
    }

    .btn-back {
        display: inline-block;
        margin-right: 10px;
        padding: 8px 15px;
        background: linear-gradient(135deg, #0ea5e9, #38bdf8);
        color: white;
        border-radius: 8px;
        text-decoration: none;
        transition: 0.3s;
    }

        .btn-back:hover {
            box-shadow: 0 0 10px #38bdf8;
            transform: scale(1.05);
        }

    .btn-warning {
        background: #ffc107;
        border: none;
    }

    .btn-danger {
        background: #ff004c;
        border: none;
    }

    .btn-info {
        background: #00c3ff;
        border: none;
        color: black;
    }

    /* CARD */
    .card {
        background: #1e293b;
        border-radius: 15px;
        box-shadow: 0 0 10px #00f7ff;
        transition: 0.3s;
        padding: 15px;
    }

        .card:hover {
            transform: scale(1.04);
            box-shadow: 0 0 25px #00f7ff;
        }
</style>

<h2 class="title">🎮 CartNest Gaming Store</h2>

<!-- 🔥 TOP BUTTONS -->
<div style="margin-bottom:20px;">

    <a asp-controller="Admin" asp-action="Dashboard" class="btn-back">
        ⬅ Back to Control Panel
    </a>

    <a asp-action="Create" class="btn-neon">
        ➕ Add New Product
    </a>

</div>

<div class="row">
    @foreach (var item in Model)
    {
        <div class="col-md-4 mb-4">
            <div class="card">

                <h4>@item.Name</h4>
                <p>@item.Description</p>

                <p><strong>💰 ₹ @item.Price</strong></p>
                <p>📦 Stock: @item.Stock</p>
                <p>🎯 Category: @item.Category?.Name</p>

                <!-- ACTION BUTTONS -->
                <div style="display:flex; justify-content:space-between; margin-top:10px;">

                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">
                        👁 Details
                    </a>

                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">
                        ✏ Edit
                    </a>

                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">
                        🗑 Delete
                    </a>

                </div>

            </div>
        </div>
    }
</div>