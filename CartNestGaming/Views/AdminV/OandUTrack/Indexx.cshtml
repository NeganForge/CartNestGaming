@model IEnumerable<CartNestGaming.Models.AppUser>

<style>
    body {
        background: #020617;
        font-family: 'Segoe UI';
        color: white;
    }

    .title {
        text-align: center;
        color: #00eaff;
        margin-top: 30px;
        margin-bottom: 40px;
        text-shadow: 0 0 10px #00eaff;
    }

    .back-btn {
        position: fixed;
        top: 20px;
        right: 30px;
        padding: 10px 20px;
        border-radius: 12px;
        background: linear-gradient(45deg, #06b6d4, #9333ea);
        color: white;
        text-decoration: none;
        font-weight: bold;
        box-shadow: 0 0 15px #9333ea;
        transition: 0.3s;
    }

        .back-btn:hover {
            transform: scale(1.08);
            box-shadow: 0 0 25px #9333ea;
        }

    .table-container {
        width: 80%;
        margin: auto;
        background: #0d1b2a;
        border-radius: 15px;
        padding: 20px;
        box-shadow: 0 0 25px #00eaff;
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    thead {
        background: #020617;
    }

    th {
        padding: 15px;
        text-align: center;
        color: #00eaff;
        font-size: 16px;
    }

    td {
        padding: 15px;
        text-align: center;
        border-top: 1px solid rgba(255,255,255,0.1);
        font-size: 15px;
    }

    tbody tr:hover {
        background: rgba(0, 234, 255, 0.08);
    }
</style>

<h2 class="title">👤 Users List</h2>

<a href="/Admin/Dashboard" class="back-btn">⬅ Back</a>

<div class="table-container">
    <table>
        <thead>
            <tr>
                <th style="width:10%;">ID</th>
                <th style="width:20%;">Name</th>
                <th style="width:40%;">Email</th>
                <th style="width:30%;">Password</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td>@user.Id</td>
                    <td>@user.Name</td>
                    <td>@user.Email</td>
                    <td>@user.Password</td>
                </tr>
            }
        </tbody>
    </table>
</div>