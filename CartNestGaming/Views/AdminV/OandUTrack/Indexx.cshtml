@model IEnumerable<CartNestGaming.Models.AppUser>

<h2 style="
    text-align:center;
    color:#00eaff;
    margin-bottom:30px;
    text-shadow:0 0 10px #00eaff;">
    👤 Users List
</h2>

<!-- 🔙 Back Button -->
<a href="/Admin/Dashboard" style="
    position:fixed;
    top:20px;
    right:30px;
    padding:10px 20px;
    border-radius:12px;
    background:linear-gradient(45deg,#06b6d4,#9333ea);
    color:white;
    text-decoration:none;
    font-weight:bold;
    box-shadow:0 0 15px #9333ea;">
    ⬅ Back
</a>

<table style="
    width:70%;
    margin:auto;
    border-collapse:collapse;
    background:#0d1b2a;
    color:white;
    box-shadow:0 0 20px #00eaff;">
    
    <thead>
        <tr style="background:#020617;">
            <th style="padding:12px;">ID</th>
            <th>Email</th>
            <th>Password</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var user in Model)
        {
            <tr style="text-align:center;">
                <td style="padding:10px;">@user.Id</td>
                <td>@user.Email</td>
                <td>@user.Password</td>
            </tr>
        }
    </tbody>
</table>