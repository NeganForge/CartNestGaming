@model IEnumerable<CartNestGaming.Models.Product>

@{
    Layout = null;
    ViewData["Title"] = "Game Store";
}

<style>
    body {
        background: #020617;
        color: white;
        font-family: 'Segoe UI';
        margin: 0;
    }

    .container {
        width: 90%;
        margin: auto;
        position: relative;
    }

    .logout-btn {
        position: absolute;
        top: 20px;
        right: 0;
        background: linear-gradient(45deg, #ef4444, #dc2626);
        padding: 10px 20px;
        border-radius: 10px;
        color: white;
        text-decoration: none;
        font-weight: bold;
        box-shadow: 0 0 10px #ef4444;
        transition: 0.3s;
    }

        .logout-btn:hover {
            box-shadow: 0 0 20px #ef4444;
            transform: scale(1.05);
        }

    h2 {
        text-align: center;
        margin-bottom: 20px;
        color: #38bdf8;
        text-shadow: 0 0 15px #38bdf8;
    }

    .search-box {
        background: #0f172a;
        padding: 20px;
        border-radius: 15px;
        box-shadow: 0 0 15px #38bdf8;
        margin-bottom: 30px;
        text-align: center;
    }

    input, select {
        padding: 10px;
        border-radius: 8px;
        border: none;
        margin-right: 10px;
        width: 200px;
    }

    button {
        background: #38bdf8;
        border: none;
        padding: 10px 20px;
        border-radius: 10px;
        font-weight: bold;
        cursor: pointer;
    }

    .row {
        display: flex;
        flex-wrap: wrap;
        gap: 20px;
        justify-content: center;
    }

    .card {
        background: #0f172a;
        border-radius: 15px;
        box-shadow: 0 0 15px #38bdf8;
        width: 250px;
        padding: 15px;
        text-align: center;
        transition: 0.3s;
    }

        .card:hover {
            transform: scale(1.05);
            box-shadow: 0 0 25px #9333ea;
        }

    .price {
        color: #38bdf8;
        font-weight: bold;
        margin: 10px 0;
    }

    .add-btn {
        background: linear-gradient(45deg, #06b6d4, #9333ea);
        padding: 10px 20px;
        border-radius: 10px;
        color: white;
        text-decoration: none;
        display: inline-block;
        margin-top: 10px;
        box-shadow: 0 0 10px #9333ea;
        transition: 0.3s;
    }

        .add-btn:hover {
            box-shadow: 0 0 20px #9333ea;
            transform: scale(1.05);
        }
</style>

<div class="container">

    <!-- ✅ FIXED LOGOUT -->
    <a asp-controller="AppUser" asp-action="Logout" class="logout-btn">
        🚪 Logout
    </a>

    <h2>🎮 Game Store</h2>

    <div class="search-box">
        <form method="get">

            <input type="text" name="searchString"
                   value="@Context.Request.Query["searchString"]"
                   placeholder="Search games..." />

            <select name="category">
                <option value="">All Categories</option>

                @foreach (var cat in ViewBag.Categories)
                {
                    <option value="@cat.Name"
                            selected="@(Context.Request.Query["category"] == cat.Name ? "selected" : null)">
                        @cat.Name
                    </option>
                }
            </select>

            <button type="submit">Search</button>

        </form>
    </div>

    <div class="row">
        @if (!Model.Any())
        {
            <p>No games found 😢</p>
        }
        else
        {
            @foreach (var item in Model)
            {
                <div class="card">
                    <h3>@item.Name</h3>
                    <p>@item.Category?.Name</p>
                    <p class="price">₹ @item.Price</p>

                    <a class="add-btn"
                           asp-controller="Cart"
                           asp-action="AddToCart"
                           asp-route-productId="@item.Id">
                        🛒 Add to Cart
                    </a>
                </div>
            }
        }
    </div>

</div>