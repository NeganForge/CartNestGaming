@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>CartNest Gaming</title>

    <style>
            body {
                margin: 0;
                font-family: 'Segoe UI', sans-serif;
                height: 100vh;
                overflow: hidden;
                color: white;
            }

            /* 🎮 BACKGROUND */
            .bg {
                position: absolute;
                width: 100%;
                height: 100%;
                background: url('/images/bg.jpg?v=4') no-repeat center center/cover;
            }

            /* 🌑 LIGHT OVERLAY */
            .overlay {
                position: absolute;
                width: 100%;
                height: 100%;
                background: rgba(0, 0, 0, 0.45);
            }

            /* 🎯 CENTER CONTENT */
            .container {
                position: relative;
                z-index: 2;
                height: 100%;
                display: flex;
                flex-direction: column;
                justify-content: center;
                align-items: center;
            }

            /* 🔥 NEON CYAN LOGO (STEAM STYLE) */
            h1 {
                font-size: 52px;
                color: #67e8f9;
                margin-bottom: 10px;
                text-shadow: 0 0 5px #22d3ee, 0 0 10px #22d3ee, 0 0 20px #06b6d4, 0 0 40px #0891b2, 0 0 80px #0e7490;
            }

            .subtitle {
                color: #e2e8f0;
                margin-bottom: 40px;
                font-size: 16px;
            }

            /* 🔥 BUTTON GROUP */
            .buttons {
                display: flex;
                gap: 20px;
            }

            .btn {
                width: 240px;
                padding: 16px;
                border-radius: 12px;
                font-size: 18px;
                font-weight: bold;
                text-align: center;
                text-decoration: none;
                transition: all 0.3s ease;
            }

            /* 🔐 ADMIN */
            .admin {
                background: linear-gradient(45deg, #38bdf8, #0ea5e9);
                color: black;
            }

                .admin:hover {
                    transform: translateY(-3px) scale(1.05);
                    box-shadow: 0 0 25px #22d3ee;
                }

            /* 👤 USER */
            .user {
                background: linear-gradient(45deg, #a855f7, #7e22ce);
                color: white;
            }

                .user:hover {
                    transform: translateY(-3px) scale(1.05);
                    box-shadow: 0 0 25px #a855f7;
                }

            /* 🟡 TAGLINE */
            .tagline {
                position: absolute;
                top: 30px;
                left: 50%;
                transform: translateX(-50%);
                font-size: 18px;
                color: #facc15;
                text-shadow: 0 0 10px #facc15;
            }
    </style>
</head>

<body>

    <!-- 🎮 Background -->
    <div class="bg"></div>

    <!-- 🌑 Overlay -->
    <div class="overlay"></div>

   

    <!-- 🎯 Main Content -->
    <div class="container">

        <h1>🎮 CartNest Gaming</h1>
        <p class="subtitle">Choose your portal</p>

        <div class="buttons">
            <a asp-controller="Auth" asp-action="AdminLogin" class="btn admin">
                🔐 Admin Login
            </a>

            <a asp-controller="AppUser" asp-action="Register" class="btn user">
                👤 User Access
            </a>
        </div>

    </div>

</body>
</html>