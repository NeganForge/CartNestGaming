@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Admin Login</title>

    <style>
        body {
            margin: 0;
            font-family: 'Segoe UI';
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            background: radial-gradient(circle at top, #020617, #020617 40%, #0f172a);
            color: white;
        }

        .login-box {
            background: #0f172a;
            padding: 40px;
            border-radius: 15px;
            width: 320px;
            box-shadow: 0 0 25px rgba(56,189,248,0.4);
            text-align: center;
            animation: fadeIn 0.6s ease-in-out;
        }

       @@keyframes fadeIn  {
            from { opacity: 0; transform: translateY(20px);}
            to { opacity: 1; transform: translateY(0);}
        }

        h2 {
            color: #38bdf8;
            text-shadow: 0 0 15px #38bdf8;
            margin-bottom: 20px;
        }

        input {
            width: 100%;
            padding: 12px;
            margin: 10px 0;
            border-radius: 10px;
            border: none;
            background: #1e293b;
            color: white;
            outline: none;
        }

        input:focus {
            box-shadow: 0 0 10px #38bdf8;
        }

        button {
            width: 100%;
            padding: 12px;
            margin-top: 15px;
            border-radius: 10px;
            border: none;
            background: linear-gradient(45deg, #38bdf8, #0ea5e9);
            color: black;
            font-weight: bold;
            cursor: pointer;
            transition: 0.3s;
        }

        button:hover {
            transform: scale(1.05);
            box-shadow: 0 0 20px #38bdf8;
        }

        .error {
            color: #f87171;
            margin-top: 10px;
        }

        .back {
            margin-top: 15px;
            display: block;
            color: #94a3b8;
            text-decoration: none;
            font-size: 14px;
        }

        .back:hover {
            color: #38bdf8;
        }

    </style>
</head>

<body>

<div class="login-box">

    <h2>🎮 Admin Login</h2>

    <form asp-controller="Auth" asp-action="AdminLogin" method="post">

        <input type="text" name="username" placeholder="Enter Username" required />

        <input type="password" name="password" placeholder="Enter Password" required />

        <button type="submit">Login</button>

    </form>

    @if (ViewBag.Error != null)
    {
        <p class="error">@ViewBag.Error</p>
    }

    <a asp-controller="Home" asp-action="LoginChoice" class="back">
        ⬅ Back to Login Choice
    </a>

</div>

</body>
</html>